# --- Archivos locales de trabajo (NO subir) ---
*.local.txt
PLAN_DE_TRABAJO.local.txt
.local/
notes/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Entornos virtuales ---
.venv/
venv/
env/
ENV/

# --- Jupyter / IDE ---
.ipynb_checkpoints/
.vscode/
.idea/

# --- Datos (respeta regla anti-flooding) ---
# Los crudos pesados y los artefactos generados en runtime NO van al repo;
# se conservan solo los directorios (.gitkeep).
data/raw_pdfs/*
!data/raw_pdfs/.gitkeep
data/snapshots/*
!data/snapshots/.gitkeep
data/processed/*
!data/processed/.gitkeep
*.parquet

# --- Sistema operativo ---
.DS_Store
Thumbs.db

# --- Secretos / configuracion local ---
.env
*.key
secrets.*
